# Copy this file to .env (project root) and fill in your values.
# Only GROQ_API_KEY, DISCORD_BOT_TOKEN and DISCORD_CHANNEL_ID are required.

# --- Groq (OpenAI-compatible endpoint) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Discord ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=            # optional: instant slash-command sync to this guild

# --- Crawling / push ---
ARXIV_QUERY=cat:cs.AI
DAILY_COUNT=5
REPORT_COUNT=8
PUSH_HOUR=9                  # local hour
PUSH_MINUTE=0               # local minute
PUSH_TZ_OFFSET=8            # timezone offset in hours (+8 = Taiwan)

# --- Multi-platform notifications (optional; skipped if unset) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_TO=                   # comma-separated recipients
LINE_CHANNEL_TOKEN=         # LINE Messaging API (LINE Notify is discontinued)
LINE_TO=

# --- Advanced RAG (optional) ---
# Embedding model. Default is small & offline-friendly. Upgrade to BGE-M3 for
# stronger multilingual retrieval (~2.2G download, 1024-dim). Changing the model
# changes vector dimension — the store auto-detects this and rebuilds on next run.
EMBED_MODEL=all-MiniLM-L6-v2           # or: BAAI/bge-m3
INDEX_TYPE=flat                        # flat (exact) or hnsw (approximate NN, faster at scale)
HNSW_M=32                              # HNSW neighbours per node (higher = better recall, more memory)
RERANK_ENABLED=0                       # 1 to enable BGE cross-encoder reranking on /ask
RERANK_MODEL=BAAI/bge-reranker-v2-m3   # downloaded on first use (~568M)

# --- Extra crawlers (optional) ---
GITHUB_TOKEN=               # optional, raises GitHub API rate limits
X_BEARER_TOKEN=             # X (Twitter) API v2 (paid plan required)

# --- Dashboard API (FastAPI) ---
JWT_SECRET=                 # required in production; ephemeral (logins reset on restart) if unset
JWT_EXPIRE_MINUTES=10080    # token lifetime, default 7 days
CORS_ORIGINS=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- OAuth sign-in / account linking (optional; provider hidden if unset) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Store backend ---
STORE_BACKEND=sqlite        # sqlite (local SQLite+FAISS) or postgres (Postgres+pgvector)
DATABASE_URL=               # e.g. postgresql://air:air@db:5432/air_agent (compose --profile postgres)
POSTGRES_PASSWORD=air       # compose db service password (keep in sync with DATABASE_URL)

# --- Per-user notification scheduler (APScheduler) ---
SCHEDULER_ENABLED=0         # 1 in deployment; compose sets this automatically
